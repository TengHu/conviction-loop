# conviction-loop — environment template
# Copy this file to .env and fill in real values. .env is gitignored; never commit it.
#   cp .env.example .env
#
# Variable names below follow the common conventions for each integration —
# adjust them to match whatever your Alpaca MCP server / Plaid CLI actually reads.

# --- Alpaca (live prices & quotes for verdict + sizing; read-only) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Use the paper endpoint unless you have a reason not to. Market data is read-only either way.
ALPACA_PAPER_TRADE=True

# --- Plaid (optional — reconcile real holdings + NAV) ---
# Leave blank to skip Plaid and enter holdings manually.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
